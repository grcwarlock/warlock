        "controls": [
          {
            "id": "art35-1",
            "title": "DPIA Requirements",
            "props": [
              {
                "name": "label",
                "value": "Art35-1"
              },
              {
                "name": "sort-id",
                "value": "art35-1"
              }
            ],
            "parts": [
              {
                "id": "art35-1_smt",
                "name": "statement",
                "prose": "Carry out DPIA where processing is likely to result in high risk."
