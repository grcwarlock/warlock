# ============================================================
# Warlock GRC Platform — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Core ---
WLK_DATABASE_URL=postgresql://warlock:changeme@localhost:5432/warlock
WLK_ENV=development  # development, staging, production
WLK_LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR
WLK_LOG_FORMAT=text  # text, json

# --- Pipeline ---
WLK_PIPELINE_BATCH_SIZE=500
WLK_PIPELINE_TIMEOUT_SECONDS=300

# --- Authentication (REQUIRED in production) ---
WLK_JWT_SECRET=  # SECRET — min 32 chars, required in production
WLK_JWT_EXPIRE_MINUTES=60

# --- Encryption ---
WLK_ENCRYPTION_KEY=  # SECRET — key for field-level encryption

# --- API Server ---
WLK_API_HOST=0.0.0.0
WLK_API_PORT=8000
WLK_API_RELOAD=false
WLK_CORS_ORIGINS=  # comma-separated list of allowed origins, e.g. http://localhost:3000

# --- Queue ---
WLK_QUEUE_BACKEND=memory          # memory, redis, kafka, sqs
WLK_QUEUE_URL=                    # redis://localhost:6379 | kafka broker | SQS region
WLK_QUEUE_PREFIX=warlock
WLK_QUEUE_CONSUMER_GROUP=warlock-pipeline
WLK_QUEUE_MAX_RETRIES=3
WLK_QUEUE_BATCH_SIZE=100

# --- Scheduler ---
WLK_SCHEDULER_INTERVAL_MINUTES=60      # pipeline collection interval
WLK_SNAPSHOT_INTERVAL_MINUTES=1440     # posture snapshot interval (daily)
WLK_CADENCE_CHECK_INTERVAL_MINUTES=60  # cadence check interval

# --- Retention ---
WLK_CHANGE_EVENT_RETENTION_DAYS=90  # auto-purge change events older than this

# --- OPA Policy Enforcement ---
WLK_OPA_URL=        # OPA decision endpoint URL, e.g. http://opa:8181/v1/data/warlock/allow
WLK_OPA_FAIL_MODE=open  # open (allow if OPA down) or closed (deny if OPA down)

# --- AI Reasoning (defaults: Ollama Cloud + qwen3-coder:30b) ---
WLK_AI_PROVIDER=ollama        # anthropic, openai, gemini, ollama
WLK_AI_API_KEY=               # SECRET — Ollama Cloud key, or Anthropic/OpenAI/Gemini key
WLK_AI_MODEL=qwen3-coder:30b  # e.g. qwen3-coder:30b, claude-sonnet-4-20250514, gpt-4o
WLK_AI_BASE_URL=https://api.ollama.com  # Ollama Cloud; use http://localhost:11434 for local
WLK_AI_CONFIDENCE_FLOOR=0.7   # minimum AI confidence to accept assessment
WLK_AI_TEMPERATURE=0.0        # LLM temperature (0.0 for reproducibility)

# ============================================================
# Connectors — Cloud Providers
# ============================================================

# --- AWS ---
WLK_AWS_ENABLED=false
WLK_AWS_REGIONS=us-east-1          # comma-separated list
WLK_AWS_ASSUME_ROLE_ARN=           # arn:aws:iam::123456789012:role/WarlockRole

# --- Azure ---
WLK_AZURE_ENABLED=false
WLK_AZURE_SUBSCRIPTION_ID=
WLK_AZURE_TENANT_ID=

# --- GCP ---
WLK_GCP_ENABLED=false
WLK_GCP_PROJECT_ID=

# --- Oracle Cloud (OCI) ---
WLK_OCI_ENABLED=false
WLK_OCI_REGION=us-ashburn-1
WLK_OCI_COMPARTMENT_ID=
WLK_OCI_TENANCY_ID=

# --- IBM Cloud ---
WLK_IBM_CLOUD_ENABLED=false
WLK_IBM_CLOUD_REGION=us-south
WLK_IBM_CLOUD_ACCOUNT_ID=

# --- Alibaba Cloud ---
WLK_ALIBABA_ENABLED=false
WLK_ALIBABA_REGION=cn-hangzhou

# --- DigitalOcean ---
WLK_DIGITALOCEAN_ENABLED=false

# --- Huawei Cloud ---
WLK_HUAWEI_ENABLED=false
WLK_HUAWEI_REGION=cn-north-4
WLK_HUAWEI_PROJECT_ID=

# --- OVHcloud ---
WLK_OVH_ENABLED=false
WLK_OVH_SERVICE_NAME=
WLK_OVH_ENDPOINT=eu.api.ovh.com

# --- Cloudflare ---
WLK_CLOUDFLARE_ENABLED=false
WLK_CLOUDFLARE_ACCOUNT_ID=
WLK_CLOUDFLARE_ZONE_IDS=  # comma-separated list of zone IDs

# ============================================================
# Connectors — EDR (Endpoint Detection & Response)
# ============================================================

